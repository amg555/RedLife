# ========================================
# REDLIFE: ENVIRONMENT CONFIGURATION
# ========================================

# For viral-quality, unhinged insights, we HIGHLY RECOMMEND OpenAI or Anthropic.
# (Running locally with Ollama works, but the brutal accuracy suffers due to model size)

LLM_PROVIDER=openai

# --- OPENAI (RECOMMENDED) ---
LLM_MODEL=gpt-5.4
OPENAI_API_KEY=sk-your-openai-api-key-here

# --- ANTHROPIC (RECOMMENDED ALTERNATIVE) ---
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-4.6-sonnet
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# --- OLLAMA (FREE & LOCAL, BUT WEAKER) ---
# LLM_PROVIDER=ollama
# LLM_MODEL=llama3.1
OLLAMA_BASE_URL=http://localhost:11434

# ========================================
# AGENT SCALING CONFIGURATION
# ========================================
# Total agents to spawn per simulation (20-1000)
# More agents = more accurate + more diverse critiques, but more LLM calls
AGENT_COUNT=100

# Batch size for parallel LLM calls (keep under your API rate limit)
# OpenAI: 10-20 is safe | Ollama local: 3-5 | Anthropic: 5-10
AGENT_BATCH_SIZE=10

# How many agents participate in Round 2 cross-debate
# Not all agents need to debate — just the most impactful ones
DEBATE_SAMPLE_SIZE=30

# Seed for deterministic agent generation (same seed = same agent pool)
AGENT_GENERATION_SEED=42

# ========================================
# ADVANCED ENGINE SETTINGS
# ========================================
# Be careful: Setting concurrency too high will rate-limit your API key
MAX_CONCURRENT_LLM_CALLS=10
LLM_TIMEOUT_SECONDS=120
