# ==============================================================================
# REDLIMITS/REDLIFE: Master .gitignore for Fullstack Architecture
# ==============================================================================

# ------------------------------------------------------------------------------
# Security & Environment Variables (NEVER COMMIT THESE)
# ------------------------------------------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem
secrets.json

# ------------------------------------------------------------------------------
# Databases & Local Storage
# ------------------------------------------------------------------------------
*.db
*.sqlite
*.sqlite3
redlife_local.db
data/
sqlite_data/

# ------------------------------------------------------------------------------
# Backend: Python / FastAPI
# ------------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ------------------------------------------------------------------------------
# Frontend: Node.js / React / Vite
# ------------------------------------------------------------------------------
node_modules/
dist/
build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store

# ------------------------------------------------------------------------------
# Python Virtual Environments
# ------------------------------------------------------------------------------
venv/
.venv/
env/
.env_venv/
ENV/
env.bak/
venv.bak/

# ------------------------------------------------------------------------------
# Diagnostics & Logs
# ------------------------------------------------------------------------------
*.log
diagnose_backend.py
hello.py
/logs/
pip-log.txt
pip-delete-this-directory.txt

# ------------------------------------------------------------------------------
# OS/Platform Generated & IDE Specific
# ------------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDEs
.idea/
.vscode/
*.swp
*.swo
*.swn
.project
.classpath
.settings/
